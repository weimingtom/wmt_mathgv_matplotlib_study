   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 四叶玫瑰线\n",
    "# abs(5*sin(2*Theta))\n",
    "# 负值咋处理‌：在极坐标里，有时候算出来 \n",
    "# ρ 是负数，这时候点会画在相反的方向上，正是这个规则让二、四象限也长出了花瓣\n",
    "Theta = np.r_[0 : 2 * np.pi : 2 * np.pi / 10000 ]\n",
    "R = np.abs(5 * np.sin(2 * Theta))\n",
    "\n",
    "plt.polar(Theta,R,linewidth=3,color='r')"
   ]
  },
